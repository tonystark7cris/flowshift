<?xml version="1.0" encoding="utf-8"?>
<WorkflowDocument yxmdVer="2023.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="BasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File>sales_data.csv</File>
        </Configuration>
        <Annotation>
          <Name>Load Sales</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Plugin="BasePluginsGui.Filter.Filter">
        <Position x="174" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <Expression>[Revenue] &gt; 1000 AND [Status] != "Inactive"</Expression>
        </Configuration>
        <Annotation>
          <Name>High Value</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="BasePluginsGui.Select.Select">
        <Position x="294" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <SelectFields>
            <SelectField field="CustomerID" selected="True" type="Int32"/>
            <SelectField field="Revenue" selected="True" type="Double"/>
            <SelectField field="Region" selected="True" type="V_String"/>
            <SelectField field="InternalNote" selected="False"/>
          </SelectFields>
        </Configuration>
        <Annotation>
          <Name>Select Cols</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="BasePluginsGui.Summarize.Summarize">
        <Position x="414" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <SummarizeFields>
            <SummarizeField field="Region" action="GroupBy"/>
            <SummarizeField field="Revenue" action="Sum"/>
            <SummarizeField field="CustomerID" action="Count"/>
          </SummarizeFields>
        </Configuration>
        <Annotation>
          <Name>Revenue by Region</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="5">
      <GuiSettings Plugin="BasePluginsGui.Sort.Sort">
        <Position x="534" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <SortInfo>
            <Field field="Revenue" order="Descending"/>
          </SortInfo>
        </Configuration>
        <Annotation>
          <Name>Sort Desc</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="6">
      <GuiSettings Plugin="BasePluginsGui.DbFileOutput.DbFileOutput">
        <Position x="654" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File>regional_summary.csv</File>
        </Configuration>
        <Annotation>
          <Name>Save Report</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="7">
      <GuiSettings Plugin="BasePluginsGui.Formula.Formula">
        <Position x="294" y="174"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <FormulaFields>
            <FormulaField field="ProfitMargin" expression="[Revenue] / [Cost] * 100"/>
          </FormulaFields>
        </Configuration>
        <Annotation>
          <Name>Calc Margin</Name>
        </Annotation>
      </Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection>
      <Origin ToolID="1" Connection="Output"/>
      <Destination ToolID="2" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="2" Connection="T"/>
      <Destination ToolID="3" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="3" Connection="Output"/>
      <Destination ToolID="4" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="4" Connection="Output"/>
      <Destination ToolID="5" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="5" Connection="Output"/>
      <Destination ToolID="6" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="2" Connection="F"/>
      <Destination ToolID="7" Connection="Input"/>
    </Connection>
  </Connections>
  <Properties>
    <RuntimeProperties>
      <WorkflowType>Module</WorkflowType>
    </RuntimeProperties>
  </Properties>
</WorkflowDocument>
